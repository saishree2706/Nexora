<section id="about">
  <div class="about-grid">
    <div class="about-img-wrap rvl">
      <div class="corner-tl"></div>
      <div class="corner-br"></div>
      <img
        src="/about.png"
        alt="Engineering"
        loading="lazy"
      />
    </div>
    <div class="rvr">
      <div class="s-label"><span class="sec-num">01 /</span> Who We Are</div>
      <h2 class="s-title">
        Engineering Excellence Rooted in 
        <span style="color:var(--b)">Silicon Beach City</span>
      </h2>
      <p class="s-desc">
        <strong style="color:var(--white)">Nexora Global Engineering Solutions Pvt. Ltd.</strong> is a specialized
        multidisciplinary engineering organization formed by experienced professionals with deep
        expertise in <span style="color:var(--g)">plant engineering,</span> both
        <a class="ind-link ind-link--strong" href="#industries">offshore</a> and
        <a class="ind-link ind-link--strong" href="#industries">onshore</a> systems.
      </p>
      <p class="s-desc" style="margin-top:1rem">
        With a strong foundation in coastal Karnataka, Silicon Beach City, we combine regional
        technical strength with global engineering practices to deliver high-quality, cost-efficient
        solutions across the full project lifecycle.
      </p>
      <div class="vm-grid">
        <div class="vm-card">
          <h4>Vision</h4>
          <p>To become a globally trusted engineering partner delivering innovative and sustainable solutions.</p>
        </div>
        <div class="vm-card">
          <h4>Mission</h4>
          <p>High-quality, cost-efficient engineering services through technical excellence and collaboration.</p>
        </div>
      </div>
    </div>
  </div>
</section>
