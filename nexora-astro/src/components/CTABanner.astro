---
import Icon from './Icon.astro';
---
<section id="cta-banner" aria-labelledby="cta-headline">
  <div class="cta-inner">
    <div class="cta-grid-bg" aria-hidden="true"></div>
    <div class="cta-content">
      <span class="cta-eyebrow">
        <span class="cta-eyebrow-dot"></span>
        Available · Q3 / Q4 2026
      </span>
      <h2 id="cta-headline" class="cta-headline">
        Have a project on the table?<br/>
        <span class="cta-grad">Let's engineer it together.</span>
      </h2>
      <p class="cta-sub">
        Brief us in a single message — we'll come back with a clear next step within one working day.
      </p>
    </div>
    <div class="cta-actions">
      <a href="#contact" class="btn btn-p cta-btn">
        Start a Conversation
        <span class="btn-arrow">→</span>
      </a>
      <a href="#services" class="btn btn-o cta-btn">
        Explore Services
      </a>
      <div class="cta-stats">
        <div class="cta-stat">
          <span class="cta-stat-n" data-val="20" data-suffix="+">0</span>
          <span class="cta-stat-l">Years core experience</span>
        </div>
        <div class="cta-stat">
          <span class="cta-stat-n" data-val="100" data-suffix="%">0</span>
          <span class="cta-stat-l">Global standards</span>
        </div>
      </div>
    </div>
  </div>
</section>
