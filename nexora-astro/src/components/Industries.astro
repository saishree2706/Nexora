---
import { Image } from 'astro:assets';
import { verticals } from '../data/industries.js';

// Eagerly import vertical images so we can resolve one by filename.
const verticalImages = import.meta.glob('../assets/verticals/*.{png,jpg,jpeg,webp}', {
  eager: true,
  import: 'default',
});
---
<section id="industries">
  <div class="rv">
    <div class="s-label"><span class="sec-num">03 /</span> Sectors We Serve</div>
    <h2 class="s-title">Two Core Verticals</h2>
    <p class="s-desc">
      End-to-end engineering across the full energy and process value chain, covering both
      <a class="ind-link ind-link--g" href="#industries">onshore</a> plants and
      <a class="ind-link ind-link--b" href="#industries">offshore</a> systems.
    </p>
  </div>

  <div class="vert-grid">
    {verticals.map((v, vi) => {
      const vImg = v.img ? verticalImages[`../assets/verticals/${v.img}`] : undefined;
      const num  = String(vi + 1).padStart(2, '0');
      return (
      <article
        class={`card vert-card rv vert-${v.accent}`}
        style={`transition-delay:${vi * 0.08}s`}
      >
        {vImg && (
          <span class="card-media">
            <Image src={vImg} alt={v.title} width={1100} quality={72} loading="lazy" />
          </span>
        )}

        <div class="card-body">
          <span class="card-kicker">{num} · Vertical</span>
          <h3 class="card-title">{v.title}</h3>
          <p class="card-text">
            Full-scope engineering delivery across {v.tags.length} {v.title.toLowerCase()} sectors.
          </p>
          <ul class="vert-tags">
            {v.tags.map((t) => (
              <li class="vert-tag">{t}</li>
            ))}
          </ul>
        </div>
      </article>
      );
    })}
  </div>
</section>
