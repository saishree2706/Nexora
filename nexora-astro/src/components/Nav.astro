---
import { site } from '../data/site.js';
---
<nav id="navbar">
  <a href="#hero" class="logo" aria-label={`${site.name} home`}>
    <img src="/nexora_new_logo.png" alt={site.legalName} width="160" height="46" />
  </a>

  <ul class="nav-links" id="navLinks">
    {site.nav.map((item) => (
      <li>
        <a href={item.href} class={item.cta ? 'nav-cta' : ''}>{item.label}</a>
      </li>
    ))}
  </ul>
  <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle light / dark theme">
    <svg class="th-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4.5"/>
      <line x1="12" y1="2" x2="12" y2="4"/>
      <line x1="12" y1="20" x2="12" y2="22"/>
      <line x1="4.5" y1="4.5" x2="5.9" y2="5.9"/>
      <line x1="18.1" y1="18.1" x2="19.5" y2="19.5"/>
      <line x1="2" y1="12" x2="4" y2="12"/>
      <line x1="20" y1="12" x2="22" y2="12"/>
      <line x1="4.5" y1="19.5" x2="5.9" y2="18.1"/>
      <line x1="18.1" y1="5.9" x2="19.5" y2="4.5"/>
    </svg>
    <svg class="th-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
    </svg>
  </button>
  <button class="hamburger" id="hbg" aria-label="Toggle menu" aria-expanded="false" aria-controls="navLinks">
    <span></span><span></span><span></span>
  </button>
</nav>
