---
import { Image } from 'astro:assets';

// Eagerly import all optimizable service images so we can resolve one by filename.
const serviceImages = import.meta.glob('../assets/services/*.{png,jpg,jpeg,webp}', {
  eager: true,
  import: 'default',
});

const { service, index } = Astro.props;
const num   = String(index + 1).padStart(2, '0');
const delay = `${index * 0.05}s`;
const img   = service.img ? serviceImages[`../assets/services/${service.img}`] : undefined;
---
<article class="card svc-card rv" style={`transition-delay:${delay}`}>
  {img && (
    <span class="card-media">
      <Image src={img} alt={service.title} width={800} quality={72} loading="lazy" />
    </span>
  )}

  <div class="card-body">
    <span class="card-kicker">{num} · Service</span>
    <h3 class="card-title">{service.title}</h3>
    {service.desc && <p class="card-text">{service.desc}</p>}
  </div>
</article>
