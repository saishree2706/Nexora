# ──────────────────────────────────────────────────────────────────────────
#  Nexora — Email / SMTP configuration
# ──────────────────────────────────────────────────────────────────────────
#  Copy this file to `.env` (same folder) and fill in real values.
#  Never commit the populated `.env` — only `.env.example` belongs in git.
#
#  The contact form (src/pages/api/contact.js) reads these vars at runtime
#  to send transactional email via Nodemailer over SMTP.
# ──────────────────────────────────────────────────────────────────────────

# ── SMTP server ─────────────────────────────────────────────────────────
# Examples:
#   Gmail            → smtp.gmail.com         port 587  (use App Password)
#   Office 365       → smtp.office365.com     port 587
#   SendGrid         → smtp.sendgrid.net      port 587  (user = "apikey")
#   Mailgun          → smtp.mailgun.org       port 587
#   Amazon SES       → email-smtp.<region>.amazonaws.com  port 587
#   Zoho Mail        → smtp.zoho.in           port 587
SMTP_HOST=smtp.example.com
SMTP_PORT=587

# Set to "true" for implicit TLS (port 465). Leave "false" / unset for
# STARTTLS on 587. Nodemailer auto-upgrades 465 → secure regardless.
SMTP_SECURE=false

# ── SMTP credentials ────────────────────────────────────────────────────
# For Gmail use an "App Password" (https://myaccount.google.com/apppasswords),
# NOT your regular Google password. 2FA must be enabled first.
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password-or-app-password

# ── From / To addresses ─────────────────────────────────────────────────
# MAIL_FROM is the visible sender. Must be an address you're allowed to
# send from (verified on SendGrid/Mailgun/SES, or matches SMTP_USER on
# Gmail/Office 365). Display-name + angle-bracket form is supported.
MAIL_FROM=Nexora Website <no-reply@nexoraglobales.com>

# MAIL_TO is where enquiries land — your sales / contact inbox.
# Multiple recipients supported via comma-separated list.
MAIL_TO=contact@nexoraglobales.com
